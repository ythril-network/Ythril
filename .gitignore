# Dependencies
node_modules/

# Build output
dist/
.angular/

# Local Docker data volumes - bind mounts, never committed
local-data/

# Runtime config - never committed; use config/config.example.json as template
config/config.json
config/secrets.json
config/schema-library.json
config/schema-catalogs.json
docker-compose.override.yml

# Test instance runtime state - generated by testing/sync/setup.js; contain token hashes
testing/sync/configs/*/config.json
testing/sync/configs/*/config.json.bak
testing/sync/configs/*/secrets.json
testing/sync/configs/*/token.txt
testing/sync/configs/*/schema-library.json
testing/sync/configs/*/schema-catalogs.json
testing/sync/configs/*/backup.json

# Env files
.env
.env.*
!.env.example

# OS / editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Local-only docs
docs/docker-build-protocol.md

# Debug artifacts
_diag_body*.json

# Logs
*.log
npm-debug.log*

# Build / test output
*.txt

# TypeScript build info
*.tsbuildinfo
server/dist
